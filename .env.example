# Copia este archivo como `.env` y reemplaza con los valores de tu proyecto Supabase.
# Los encuentras en: Supabase Dashboard -> Project Settings -> API
#
# NOTA: La "anon key" está diseñada para ser pública (viaja en el frontend).
# La seguridad real la garantiza el Row Level Security (ver supabase/schema.sql),
# no el ocultamiento de esta clave. Aun así, mantén este archivo fuera de Git.

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_ANON_KEY
